# Runtime
NODE_ENV=production
LOG_SQL=false

# Public ports
FRONTEND_PORT=5173
NGINX_PORT=3000
AUTH_PORT=3001
COMMUNITY_PORT=3002
CONTENT_PORT=3003
EXAM_PORT=3004

# Database hosts
AUTH_DB_HOST=auth-db
CONTENT_DB_HOST=content-db
COMMUNITY_DB_HOST=community-db
EXAM_DB_HOST=exam-db
AUTH_DB_PORT=5432
CONTENT_DB_PORT=5432
COMMUNITY_DB_PORT=5432
EXAM_DB_PORT=5432
AUTH_DB_HOST_PORT=5433
CONTENT_DB_HOST_PORT=5434
COMMUNITY_DB_HOST_PORT=5435
EXAM_DB_HOST_PORT=5436

# Databases
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change-me
CONTENT_DB_NAME=content_db
CONTENT_DB_USER=content_user
CONTENT_DB_PASSWORD=change-me
COMMUNITY_DB_NAME=community_db
COMMUNITY_DB_USER=community_user
COMMUNITY_DB_PASSWORD=change-me
EXAM_DB_NAME=exam_db
EXAM_DB_USER=exam_user
EXAM_DB_PASSWORD=change-me

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
CONTENT_SERVICE_URL=http://content-service:3003
COMMUNITY_SERVICE_URL=http://community-service:3002
EXAM_SERVICE_URL=http://exam-service:3004
FRONTEND_URL=http://localhost:5173
PUBLIC_FRONTEND_ORIGIN=http://localhost:5173
API_GATEWAY_URL=http://localhost:3000
VITE_API_URL=/api

# Security
JWT_SECRET=generate-a-48-byte-random-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# Database pools
DB_POOL_MAX=20
AUTH_DB_POOL_MAX=20
CONTENT_DB_POOL_MAX=20
COMMUNITY_DB_POOL_MAX=20
EXAM_DB_POOL_MAX=25
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# Rate limits
AUTH_RATE_LIMIT_MAX=3000
LOGIN_RATE_LIMIT_MAX=20
AUTH_PREFERENCES_CACHE_TTL_SECONDS=120
CONTENT_RATE_LIMIT_MAX=3000
COMMUNITY_RATE_LIMIT_MAX=3000
COMMUNITY_MESSAGE_RATE_LIMIT_MAX=12
COMMUNITY_MESSAGE_RATE_LIMIT_WINDOW_SECONDS=10

# Realtime
SOCKET_MAX_CONNECTIONS=500
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_MAX_HTTP_BUFFER_BYTES=32768
GAMIFICATION_SUMMARY_CACHE_TTL_SECONDS=15
GAMIFICATION_LEADERBOARD_CACHE_TTL_SECONDS=15

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
COMMUNITY_USER_CACHE_TTL_SECONDS=300

# Uploads
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=52428800
COMMUNITY_ALLOWED_FILE_TYPES=application/pdf
