# ========================================
# COMMUNITY SERVICE - DESARROLLO LOCAL
# ========================================

NODE_ENV=development
PORT=3002

# Database (local)
DB_HOST=localhost
DB_PORT=5434
DB_NAME=community_db
DB_USER=community_user
DB_PASSWORD=community_secure_pass_2024

# Redis (local)
REDIS_URL=redis://localhost:6379

# JWT (mismo que auth-service)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_abc123xyz789

# Auth Service (local)
AUTH_SERVICE_URL=http://localhost:3001

# Frontend
FRONTEND_URL=http://localhost:5173

# Uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Puntos
POINTS_PER_MESSAGE=1
POINTS_PER_RESOURCE=5
POINTS_PER_CHALLENGE_COMPLETED=10

# Límites
MAX_COMMUNITY_MEMBERS=100
MAX_MESSAGE_LENGTH=2000
INVITATION_EXPIRY_DAYS=7

# Logging
LOG_LEVEL=debug